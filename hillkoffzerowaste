// ============================================================
// HELPERS
// ============================================================
function calcCO2(wasteId, qtyId, disposalId) {
  const w = WASTE_TYPES.find((x) => x.id === wasteId);
  const q = QUANTITIES.find((x) => x.id === qtyId);
  const d = DISPOSALS.find((x) => x.id === disposalId);

  if (!w || !q || !d) return 0;
  return +(w.factor * q.value * d.mult).toFixed(4);
}

function saveRecords(records) {
  localStorage.setItem("hillkoff_records", JSON.stringify(records));
}

function loadRecords() {
  try {
    return JSON.parse(localStorage.getItem("hillkoff_records") || "[]");
  } catch {
    return [];
  }
}

function exportCSV(records) {
  const header = [
    "วันที่",
    "สาขา",
    "ประเภทขยะ",
    "ปริมาณ(kg)",
    "วิธีจัดการ",
    "CO2e(kg)",
  ];

  const rows = records.map((r) => [
    new Date(r.ts).toLocaleString("th-TH"),
    r.branchName,
    r.wasteLabel,
    r.qty,
    r.disposalLabel,
    r.co2e,
  ]);

  const csv = [header, ...rows].map((row) => row.join(",")).join("\n");
  const blob = new Blob(["\uFEFF" + csv], {
    type: "text/csv;charset=utf-8;",
  });

  const url = URL.createObjectURL(blob);
  const a = document.createElement("a");
  a.href = url;
  a.download = "hillkoff-zero-waste.csv";
  a.click();
  URL.revokeObjectURL(url);
}

// ============================================================
// GEMINI VISION (OPTIONAL)
// ============================================================
async function geminiAnalyze(base64, wasteLabel) {
  if (GEMINI_KEY === "YOUR_GEMINI_API_KEY") {
    return {
      match: true,
      confidence: 85,
      detected: wasteLabel,
      remark: "Demo Mode",
      geminiUsed: false,
    };
  }

  try {
    const res = await fetch(
      `https://generativelanguage.googleapis.com/v1beta/models/gemini-1.5-flash:generateContent?key=${GEMINI_KEY}`,
      {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
        },
        body: JSON.stringify({
          contents: [
            {
              parts: [
                {
                  inline_data: {
                    mime_type: "image/jpeg",
                    data: base64,
                  },
                },
                {
                  text: `วิเคราะห์ภาพและตอบ JSON:
{
  "match": true,
  "confidence": 90,
  "detected": "${wasteLabel}",
  "remark": "ผลการวิเคราะห์"
}`,
                },
              ],
            },
          ],
        }),
      }
    );

    const data = await res.json();
    const text =
      data?.candidates?.[0]?.content?.parts?.[0]?.text || "{}";
    const parsed = JSON.parse(text.replace(/```json|```/g, "").trim());

    return {
      ...parsed,
      geminiUsed: true,
    };
  } catch {
    return {
      match: false,
      confidence: 0,
      detected: "ไม่สามารถวิเคราะห์ได้",
      remark: "API Error",
      geminiUsed: false,
    };
  }
}

// ============================================================
// APP
// ============================================================
export default function App() {
  const [records, setRecords] = useState([]);
  const [step, setStep] = useState(0);
  const [photo, setPhoto] = useState(null);
  const [aiResult, setAiResult] = useState(null);
  const [loadingAI, setLoadingAI] = useState(false);

  const fileRef = useRef();

  const [form, setForm] = useState({
    branch: "",
    waste: "",
    qty: "",
    disposal: "",
  });

  useEffect(() => {
    setRecords(loadRecords());
  }, []);

  const branch = BRANCHES.find((b) => b.id === form.branch);
  const waste = WASTE_TYPES.find((w) => w.id === form.waste);
  const qty = QUANTITIES.find((q) => q.id === form.qty);
  const disposal = DISPOSALS.find((d) => d.id === form.disposal);

  const co2 =
    form.branch && form.waste && form.qty && form.disposal
      ? calcCO2(form.waste, form.qty, form.disposal)
      : 0;

  function handleSave() {
    const record = {
      id: Date.now(),
      ts: new Date().toISOString(),
      branchId: branch.id,
      branchName: branch.name,
      wasteType: waste.id,
      wasteLabel: waste.label,
      qty: qty.value,
      disposalId: disposal.id,
      disposalLabel: disposal.label,
      co2e: co2,
      aiMatch: aiResult?.match || false,
    };

    const updated = [record, ...records];
    setRecords(updated);
    saveRecords(updated);

    alert("บันทึกข้อมูลสำเร็จ");

    setForm({
      branch: "",
      waste: "",
      qty: "",
      disposal: "",
    });

    setPhoto(null);
    setAiResult(null);
    setStep(0);
  }

  function handlePhoto(e) {
    const file = e.target.files[0];
    if (!file) return;

    const reader = new FileReader();
    reader.onload = (ev) => {
      const base64 = ev.target.result.split(",")[1];
      setPhoto(base64);
      setAiResult(null);
    };
    reader.readAsDataURL(file);
  }

  async function handleAnalyze() {
    if (!photo || !waste) return;
    setLoadingAI(true);
    const result = await geminiAnalyze(photo, waste.label);
    setAiResult(result);
    setLoadingAI(false);
  }

  const totalCO2 = records.reduce((sum, r) => sum + r.co2e, 0);

  // ==========================================================
  // UI
  // ==========================================================
  return (
    <div style={styles.container}>
      <h1>☕ Hillkoff Zero Waste Platform</h1>
      <p>CO₂e รวม: {totalCO2.toFixed(3)} kg</p>

      <hr />

      <h2>บันทึกข้อมูลขยะ</h2>

      {/* Branch */}
      <label>สาขา</label>
      <select
        value={form.branch}
        onChange={(e) =>
          setForm({ ...form, branch: e.target.value })
        }
      >
        <option value="">-- เลือกสาขา --</option>
        {BRANCHES.map((b) => (
          <option key={b.id} value={b.id}>
            {b.icon} {b.name}
          </option>
        ))}
      </select>

      {/* Waste */}
      <label>ประเภทขยะ</label>
      <select
        value={form.waste}
        onChange={(e) =>
          setForm({ ...form, waste: e.target.value })
        }
      >
        <option value="">-- เลือกประเภทขยะ --</option>
        {WASTE_TYPES.map((w) => (
          <option key={w.id} value={w.id}>
            {w.icon} {w.label}
          </option>
        ))}
      </select>

      {/* Qty */}
      <label>ปริมาณ</label>
      <select
        value={form.qty}
        onChange={(e) =>
          setForm({ ...form, qty: e.target.value })
        }
      >
        <option value="">-- เลือกปริมาณ --</option>
        {QUANTITIES.map((q) => (
          <option key={q.id} value={q.id}>
            {q.label} ({q.value} kg)
          </option>
        ))}
      </select>

      {/* Disposal */}
      <label>วิธีจัดการ</label>
      <select
        value={form.disposal}
        onChange={(e) =>
          setForm({ ...form, disposal: e.target.value })
        }
      >
        <option value="">-- เลือกวิธีจัดการ --</option>
        {DISPOSALS.map((d) => (
          <option key={d.id} value={d.id}>
            {d.icon} {d.label}
          </option>
        ))}
      </select>

      <p>
        <strong>CO₂e:</strong> {co2.toFixed(4)} kg
      </p>

      {/* Photo */}
      <button onClick={() => fileRef.current.click()}>
        📷 อัปโหลดรูป
      </button>
      <input
        type="file"
        accept="image/*"
        ref={fileRef}
        style={{ display: "none" }}
        onChange={handlePhoto}
      />

      {photo && (
        <>
          <img
            src={`data:image/jpeg;base64,${photo}`}
            alt="preview"
            style={{
              width: "100%",
              maxWidth: 400,
              borderRadius: 12,
              marginTop: 12,
            }}
          />

          <button onClick={handleAnalyze} disabled={loadingAI}>
            {loadingAI
              ? "กำลังวิเคราะห์..."
              : "🤖 วิเคราะห์ด้วย Gemini"}
          </button>
        </>
      )}

      {aiResult && (
        <div style={styles.card}>
          <p>
            <strong>Detected:</strong> {aiResult.detected}
          </p>
          <p>
            <strong>Confidence:</strong>{" "}
            {aiResult.confidence}%
          </p>
          <p>{aiResult.remark}</p>
        </div>
      )}

      <button
        onClick={handleSave}
        disabled={
          !form.branch ||
          !form.waste ||
          !form.qty ||
          !form.disposal
        }
        style={styles.saveButton}
      >
        ✅ บันทึกข้อมูล
      </button>

      <hr />

      <h2>รายการล่าสุด</h2>

      <button onClick={() => exportCSV(records)}>
        📊 Export CSV
      </button>

      {records.length === 0 && <p>ยังไม่มีข้อมูล</p>}

      {records.map((r) => (
        <div key={r.id} style={styles.card}>
          <div>
            <strong>{r.branchName}</strong>
          </div>
          <div>{r.wasteLabel}</div>
          <div>{r.qty} kg</div>
          <div>{r.disposalLabel}</div>
          <div>{r.co2e} kg CO₂e</div>
        </div>
      ))}
    </div>
  );
}

