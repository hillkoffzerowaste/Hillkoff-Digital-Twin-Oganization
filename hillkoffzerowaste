async function geminiAnalyze(base64, wasteLabel) {
  if (!GEMINI_KEY || GEMINI_KEY === "YOUR_GEMINI_API_KEY") {
    await new Promise(r => setTimeout(r, 1500));
    const confidence = 75 + Math.floor(Math.random() * 22);
    return { match: confidence > 80, confidence, detected: `ตรวจพบ: ${wasteLabel}`, remark: "โหมด Demo", geminiUsed: true };
  }
  try {
    const res = await fetch(
      `https://generativelanguage.googleapis.com/v1beta/models/gemini-1.5-flash:generateContent?key=${GEMINI_KEY}`,
      {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          contents: [{ parts: [
            { inline_data: { mime_type: "image/jpeg", data: base64 } },
            { text: `คุณคือ AI ผู้เชี่ยวชาญด้านการจัดการขยะ Zero Waste ระดับองค์กร\nวิเคราะห์ภาพนี้และตอบกลับเป็น JSON เท่านั้น ไม่ต้องมี markdown:\n{\n  "match": true/false,\n  "confidence": 0-100,\n  "detected": "ชื่อขยะที่พบในภาษาไทย",\n  "remark": "ความเห็นสั้น ๆ ไม่เกิน 20 คำ"\n}\nประเภทขยะที่ผู้ใช้เลือก: "${wasteLabel}"` }
          ]}],
          generationConfig: { temperature: 0.1, maxOutputTokens: 200 }
        })
      }
    );
    const data = await res.json();
    const text = data.candidates?.[0]?.content?.parts?.[0]?.text || "{}";
    const parsed = JSON.parse(text.replace(/```json|```/g, "").trim());
    return { ...parsed, geminiUsed: true };
  } catch {
    return { match: true, confidence: 72, detected: wasteLabel, remark: "ไม่สามารถเชื่อมต่อ Gemini API ได้", geminiUsed: false };
  }
}

function exportCSV(records) {
  const header = ["วันที่","เวลา","สาขา","ประเภทขยะ","ปริมาณ(kg)","วิธีจัดการ","CO2e(kg)","AI_ยืนยัน","AI_ความมั่นใจ(%)","มาตรฐาน"];
  const rows = records.map(r => [
    new Date(r.ts).toLocaleDateString("th-TH"),
    new Date(r.ts).toLocaleTimeString("th-TH"),
    r.branchName, r.wasteLabel, r.qty, r.disposalLabel,
    r.co2e, r.aiMatch ? "ใช่" : "ไม่", r.aiConf || "-",
    WASTE_TYPES.find(w => w.id === r.wasteType)?.std || "ISO14064"
  ]);
  const csv = [header, ...rows].map(r => r.join(",")).join("\n");
  const blob = new Blob(["\uFEFF" + csv], { type: "text/csv;charset=utf-8;" });
  const a = document.createElement("a");
  a.href = URL.createObjectURL(blob);
  a.download = `Hillkoff_ZeroWaste_ESG_${new Date().toISOString().slice(0,10)}.csv`;
  a.click();
  URL.revokeObjectURL(a.href);
}

