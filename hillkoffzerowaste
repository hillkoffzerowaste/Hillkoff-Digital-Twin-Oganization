          ))}
        </div>
      )}

      {/* Step 3: Disposal */}
      {step === 3 && (
        <div style={S.col20}>
          <StepTitle>วิธีจัดการของเสีย</StepTitle>
          {DISPOSALS.map(dp => (
            <button key={dp.id} style={{ ...S.choiceRow, ...(form.disposal===dp.id ? { ...S.choiceActive, borderColor:dp.color } : {}) }}
              onClick={() => setForm(f => ({ ...f, disposal:dp.id }))}>
              <span style={{ fontSize:22 }}>{dp.icon}</span>
              <div style={{ flex:1, textAlign:"left" }}>
                <div style={{ fontWeight:700, fontSize:14 }}>{dp.label}</div>
