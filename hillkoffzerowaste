/* ─── REPORT VIEW ─── */
function ReportView({ records, branchStats, totalCO2, showToast }) {
  const [emailTo, setEmailTo] = useState("");
  const [sending, setSending] = useState(false);
  const [period, setPeriod]   = useState("all");

  const filtered = period==="all" ? records :
    period==="monthly" ? records.filter(r => getMonth(r.ts)===getMonth(Date.now())) :
    records.filter(r => getYear(r.ts)===getYear(Date.now()));

  const fStats = BRANCHES.map(b => {
    const recs = filtered.filter(r => r.branchId===b.id);
    return { ...b, count:recs.length, totalQty:recs.reduce((s,r)=>s+r.qty,0), co2:+recs.reduce((s,r)=>s+r.co2e,0).toFixed(4) };
  });
  const fTotal = +fStats.reduce((s,b)=>s+b.co2,0).toFixed(4);

  const handleSendEmail = async () => {
    if (!emailTo) { showToast("กรุณากรอก Email ผู้รับ","err"); return; }
    setSending(true);
    await new Promise(r => setTimeout(r, 1500));
    showToast(`📧 ส่งรายงานไปยัง ${emailTo} แล้ว (ทดสอบ)`, "ok");
    setSending(false);
  };

  return (
    <div style={S.col20}>
      <div style={{ ...S.heroCard, padding:"20px 20px" }}>
        <div style={{ fontSize:13, opacity:0.8 }}>📋 ESG Report Center</div>
