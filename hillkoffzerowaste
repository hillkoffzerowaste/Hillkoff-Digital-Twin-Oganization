  tagBtn:       { padding:"5px 11px", background:"#fff", border:"2px solid #ddd", borderRadius:20, fontSize:11, cursor:"pointer", color:"#666" },
  tagActive:    { border:"2px solid #145a32", color:"#145a32", fontWeight:700 },
  chartBox:     { background:"#fff", borderRadius:16, padding:"16px 14px", boxShadow:"0 2px 10px rgba(0,0,0,0.05)" },
  barRow:       { display:"flex", alignItems:"center", gap:9 },
  leaderCard:   { background:"#fff", borderRadius:16, padding:"13px 15px", display:"flex", alignItems:"center", gap:11, boxShadow:"0 2px 8px rgba(0,0,0,0.05)" },
  targetCard:   { background:"#fff", borderRadius:16, padding:"16px 18px", boxShadow:"0 2px 8px rgba(0,0,0,0.05)" },
  exportBtn:    { width:"100%", padding:14, color:"#fff", border:"none", borderRadius:13, fontSize:14, fontWeight:700, cursor:"pointer", marginBottom:2 },
  gmailCard:    { background:"#fff", borderRadius:16, padding:"16px 18px", boxShadow:"0 2px 8px rgba(0,0,0,0.05)" },
  emailInput:   { width:"100%", padding:"11px 14px", border:"2px solid #ddd", borderRadius:11, fontSize:13, marginBottom:10, boxSizing:"border-box", outline:"none", fontFamily:"inherit" },
};

/* ─── MAIN APP ─── */
function App() {
  const [view, setView]       = useState("home");
  const [records, setRecords] = useState([]);
  const [logKey, setLogKey]   = useState(0);
  const [toast, setToast]     = useState(null);

  useEffect(() => { setRecords(dbLoad()); }, []);

  const showToast = (msg, type="ok") => {
    setToast({ msg, type });
    setTimeout(() => setToast(null), 3200);
  };

  const addRecord = (rec) => {
    const updated = [rec, ...records];
    setRecords(updated);
    dbSave(updated);
    showToast("✅ บันทึกสำเร็จ!");
    setView("home");
  };

  const branchStats = BRANCHES.map(b => {
    const recs = records.filter(r => r.branchId === b.id);
    return {
      ...b,
      count:    recs.length,
      totalQty: recs.reduce((s,r) => s+r.qty, 0),
      co2:      +recs.reduce((s,r) => s+r.co2e, 0).toFixed(4),
    };
  });
  const totalCO2 = +branchStats.reduce((s,b) => s+b.co2, 0).toFixed(4);

  const TABS = [
    { id:"home",        icon:"🏠", label:"หน้าหลัก" },
    { id:"log",         icon:"📝", label:"บันทึก" },
    { id:"analytics",   icon:"📊", label:"Analytics" },
    { id:"leaderboard", icon:"🏆", label:"Ranking" },
    { id:"report",      icon:"📋", label:"รายงาน" },
  ];

  return (
    <div style={S.root}>
      {/* Background */}
      <div style={{ position:"fixed", inset:0, background:"radial-gradient(ellipse at 20% 20%, #d5f5e3 0%, transparent 60%), radial-gradient(ellipse at 80% 80%, #d1f2eb 0%, transparent 60%), #f0f7f2", zIndex:0 }} />

      {/* Toast */}
      {toast && (
        <div style={{ ...S.toast, background: toast.type==="ok" ? "#145a32" : "#c0392b" }}>
          {toast.msg}
        </div>
      )}

      {/* Header */}
      <header style={S.header}>
        <div style={S.logoWrap}>
          <span style={{ fontSize:26 }}>☕</span>
          <div>
            <div style={S.logoName}>Hillkoff</div>
            <div style={S.logoSub}>Zero Waste · ESG Platform</div>
          </div>
        </div>
        <div style={S.co2Pill}>
          <span style={{ fontSize:10, opacity:0.75 }}>CO₂e รวม</span>
          <span style={{ fontSize:17, fontWeight:800 }}>{totalCO2.toFixed(2)} kg</span>
        </div>
      </header>

      {/* Main content */}
      <main style={S.main}>
        {view==="home"        && <HomeView        branchStats={branchStats} totalCO2={totalCO2} records={records} onLog={() => { setLogKey(k=>k+1); setView("log"); }} />}
        {view==="log"         && <LogView         key={logKey} onAdd={addRecord} showToast={showToast} />}
        {view==="analytics"   && <AnalyticsView   records={records} branchStats={branchStats} />}
        {view==="leaderboard" && <LeaderboardView branchStats={branchStats} totalCO2={totalCO2} records={records} />}
        {view==="report"      && <ReportView      records={records} branchStats={branchStats} totalCO2={totalCO2} showToast={showToast} />}
      </main>

      {/* Bottom Nav */}
      <nav style={S.nav}>
        {TABS.map(t => (
          <button key={t.id}
            style={{ ...S.navBtn, ...(view===t.id ? S.navActive : {}) }}
            onClick={() => { if (t.id==="log") setLogKey(k=>k+1); setView(t.id); }}>
            <span style={{ fontSize:20 }}>{t.icon}</span>
            <span style={{ fontSize:9.5 }}>{t.label}</span>
          </button>
        ))}
      </nav>
    </div>
  );
}

ReactDOM.createRoot(document.getElementById("root")).render(<App />);
</script>
</body>
</html>
