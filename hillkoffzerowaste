              <span style={{ fontSize:22 }}>⚖️</span>
              <div style={{ flex:1, textAlign:"left" }}>
                <div style={{ fontWeight:700, fontSize:14 }}>{qt.label}</div>
                <div style={{ fontSize:12, color:"#666" }}>{qt.sub}</div>
              </div>
              <span style={{ fontWeight:800, fontSize:13, color:"#145a32" }}>{qt.value} kg</span>
