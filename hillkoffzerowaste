              <span style={{ fontSize:28 }}>{aiRes.match ? "✅" : "⚠️"}</span>
              <div style={{ flex:1 }}>
                <div style={{ fontWeight:700, color: aiRes.match ? "#145a32" : "#c0392b", fontSize:13 }}>
                  {aiRes.match ? "Gemini ยืนยัน: ตรงประเภท" : "Gemini: อาจไม่ตรงประเภท"}
                </div>
                <div style={{ fontSize:12, color:"#444" }}>{aiRes.detected}</div>
                <div style={{ fontSize:11, color:"#777" }}>{aiRes.remark}</div>
              </div>
              <div style={S.confBadge}>{aiRes.confidence}%</div>
            </div>
          )}

          <button style={{ ...S.submitBtn, opacity: saving ? 0.6 : 1 }}
            disabled={saving} onClick={handleSubmit}>
            {saving ? "⏳ กำลังบันทึก..." : "✅ บันทึกข้อมูล (ISO 14064)"}
          </button>
        </div>
      )}

      {/* Navigation */}
      <div style={{ display:"flex", gap:10 }}>
        {step > 0 && <button style={S.backBtn} onClick={() => setStep(s => s-1)}>← ย้อนกลับ</button>}
        {step < 4 && (
          <button style={{ ...S.nextBtn, opacity: canNext[step] ? 1 : 0.35 }}
            disabled={!canNext[step]} onClick={() => setStep(s => s+1)}>
            ถัดไป →
          </button>
        )}
      </div>
    </div>
  );
}

/* ─── ANALYTICS VIEW ─── */
function AnalyticsView({ records, branchStats }) {
  const [period, setPeriod]               = useState("monthly");
  const [selectedBranch, setSelectedBranch] = useState("all");

  const filtered = selectedBranch === "all" ? records : records.filter(r => r.branchId === selectedBranch);

  const grouped = {};
  filtered.forEach(r => {
    const key = period==="daily" ? getDay(r.ts) : period==="monthly" ? getMonth(r.ts) : getYear(r.ts);
    if (!grouped[key]) grouped[key] = { co2:0, count:0, qty:0 };
    grouped[key].co2   += r.co2e;
    grouped[key].count += 1;
    grouped[key].qty   += r.qty;
  });

  const entries = Object.entries(grouped).sort((a,b) => a[0].localeCompare(b[0])).slice(-12);
  const maxCO2  = Math.max(...entries.map(e => e[1].co2), 0.001);

  const wasteBreak = WASTE_TYPES.map(wt => ({
    ...wt,
    total: +filtered.filter(r => r.wasteType === wt.id).reduce((s,r) => s+r.co2e, 0).toFixed(3)
  })).filter(w => w.total > 0).sort((a,b) => b.total - a.total);

  const maxBranch = Math.max(...branchStats.map(b => b.co2), 0.001);

  return (
    <div style={S.col20}>
      <div style={{ display:"flex", gap:8 }}>
        {[["daily","รายวัน"],["monthly","รายเดือน"],["yearly","รายปี"]].map(([p,lbl]) => (
          <button key={p} style={{ ...S.periodBtn, ...(period===p ? S.periodActive : {}) }}
            onClick={() => setPeriod(p)}>{lbl}</button>
        ))}
      </div>

      <div style={{ display:"flex", gap:6, flexWrap:"wrap" }}>
        <button style={{ ...S.tagBtn, ...(selectedBranch==="all" ? S.tagActive : {}) }}
          onClick={() => setSelectedBranch("all")}>ทุกสาขา</button>
        {BRANCHES.map(b => (
          <button key={b.id} style={{ ...S.tagBtn, ...(selectedBranch===b.id ? { ...S.tagActive, borderColor:b.color, background:b.color+"20" } : {}) }}
            onClick={() => setSelectedBranch(b.id)}>{b.icon} {b.name}</button>
        ))}
      </div>

      <div style={S.chartBox}>
        <div style={{ fontSize:12, fontWeight:700, color:"#145a32", marginBottom:10 }}>
          CO₂e {period==="daily" ? "รายวัน" : period==="monthly" ? "รายเดือน" : "รายปี"} (kg)
        </div>
        {entries.length === 0 && <Empty />}
        <div style={{ display:"flex", alignItems:"flex-end", gap:6, height:130 }}>
          {entries.map(([k, v]) => (
            <div key={k} style={{ flex:1, display:"flex", flexDirection:"column", alignItems:"center", gap:3, height:"100%", justifyContent:"flex-end" }}>
              <div style={{ fontSize:8, color:"#888", fontWeight:600 }}>{v.co2.toFixed(2)}</div>
              <div style={{ width:"100%", background:"linear-gradient(180deg,#27ae60,#145a32)", borderRadius:"6px 6px 0 0", height:`${(v.co2/maxCO2)*110}px`, minHeight: v.co2 > 0 ? 4 : 0, transition:"height 0.4s" }} />
              <div style={{ fontSize:7.5, color:"#999", textAlign:"center", lineHeight:1.2 }}>
                {period==="monthly" ? k.slice(5) : k}
              </div>
            </div>
          ))}
        </div>
      </div>

      <SectionTitle>CO₂e แยกตามประเภทขยะ</SectionTitle>
      {wasteBreak.map(w => (
        <div key={w.id} style={S.recordRow}>
          <span style={{ fontSize:22 }}>{w.icon}</span>
          <div style={{ flex:1 }}>
            <div style={{ fontSize:12, fontWeight:700 }}>{w.label}</div>
            <div style={{ fontSize:10, color:"#888" }}>{w.std} · factor {w.factor}</div>
          </div>
          <div style={{ fontWeight:800, fontSize:13, color:"#145a32" }}>{w.total} kg CO₂e</div>
        </div>
      ))}
      {wasteBreak.length === 0 && <Empty />}

      <SectionTitle>เปรียบเทียบสาขา</SectionTitle>
      {branchStats.map(b => (
        <div key={b.id} style={S.barRow}>
          <div style={{ width:64, fontSize:10.5, fontWeight:700 }}>{b.icon} {b.short}</div>
          <div style={{ flex:1, height:22, background:"#e8f5e9", borderRadius:11, overflow:"hidden" }}>
            <div style={{ height:"100%", width:`${(b.co2/maxBranch)*100}%`, background:`linear-gradient(90deg,${b.color},${b.color}bb)`, borderRadius:11, transition:"width 0.5s" }} />
          </div>
          <div style={{ width:54, textAlign:"right", fontSize:11, fontWeight:800, color:b.color }}>{b.co2} kg</div>
        </div>
      ))}
    </div>
  );
}

