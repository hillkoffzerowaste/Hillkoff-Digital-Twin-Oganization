/* ─── LOG VIEW ─── */
function LogView({ onAdd, showToast }) {
  const [step, setStep]         = useState(0);
  const [form, setForm]         = useState({ branch:null, waste:null, qty:null, disposal:null });
  const [photo, setPhoto]       = useState(null);
  const [aiRes, setAiRes]       = useState(null);
  const [aiLoading, setAiLoading] = useState(false);
  const [saving, setSaving]     = useState(false);
  const fileRef = useRef();

  const w  = WASTE_TYPES.find(x => x.id === form.waste);
  const q  = QUANTITIES.find(x => x.id === form.qty);
  const d  = DISPOSALS.find(x => x.id === form.disposal);
  const co2Preview = (form.waste && form.qty && form.disposal) ? calcCO2(form.waste, form.qty, form.disposal) : null;
  const canNext = [!!form.branch, !!form.waste, !!form.qty, !!form.disposal, true];

  const handlePhoto = (e) => {
    const file = e.target.files[0]; if (!file) return;
    const reader = new FileReader();
    reader.onload = ev => { setPhoto(ev.target.result.split(",")[1]); setAiRes(null); };
    reader.readAsDataURL(file);
  };

  const runGemini = async () => {
    if (!photo || !form.waste) return;
    setAiLoading(true);
    const result = await geminiAnalyze(photo, w?.label || "");
    setAiRes(result);
    setAiLoading(false);
  };

  const handleSubmit = async () => {
    setSaving(true);
    const branch = BRANCHES.find(b => b.id === form.branch);
    const rec = {
      id:           Date.now(),
      ts:           new Date().toISOString(),
      branchId:     form.branch,
      branchName:   branch?.name,
      wasteType:    form.waste,
      wasteLabel:   w?.label,
      qty:          q?.value,
      disposalId:   form.disposal,
      disposalLabel: d?.label,
      co2e:         co2Preview,
      hasPhoto:     !!photo,
      aiMatch:      aiRes?.match ?? false,
      aiConf:       aiRes?.confidence ?? null,
      geminiUsed:   aiRes?.geminiUsed ?? false,
    };
    await onAdd(rec);
    setSaving(false);
  };

  const STEP_LABELS = ["สาขา","ประเภท","ปริมาณ","วิธีจัดการ","หลักฐาน"];

  return (
    <div style={S.col20}>
      {/* Progress */}
      <div style={{ display:"flex", gap:6, alignItems:"center" }}>
        {STEP_LABELS.map((lbl, i) => (
          <div key={i} style={{ flex:1, display:"flex", flexDirection:"column", alignItems:"center", gap:4 }}>
            <div style={{ width:26, height:26, borderRadius:"50%", background: i<step?"#1e8449": i===step?"#145a32":"#d5e8d4", color: i<=step?"#fff":"#999", display:"flex", alignItems:"center", justifyContent:"center", fontSize:11, fontWeight:700 }}>
              {i < step ? "✓" : i+1}
            </div>
            <span style={{ fontSize:8.5, color: i<=step?"#145a32":"#bbb" }}>{lbl}</span>
          </div>
        ))}
      </div>

      {/* Step 0: Branch */}
      {step === 0 && (
        <div style={S.col20}>
          <StepTitle>เลือกสาขา</StepTitle>
          <div style={S.grid3}>
            {BRANCHES.map(b => (
              <button key={b.id} style={{ ...S.choiceCard, ...(form.branch===b.id ? { borderColor:b.color, background:b.color+"18" } : {}) }}
                onClick={() => setForm(f => ({ ...f, branch:b.id }))}>
                <span style={{ fontSize:26 }}>{b.icon}</span>
                <span style={{ fontSize:10.5, fontWeight:700, color:"#1a3a2a", lineHeight:1.3 }}>{b.name}</span>
              </button>
            ))}
          </div>
        </div>
      )}

      {/* Step 1: Waste */}
      {step === 1 && (
        <div style={S.col20}>
          <StepTitle>ประเภทของเสีย</StepTitle>
          <div style={S.grid3}>
            {WASTE_TYPES.map(wt => (
              <button key={wt.id} style={{ ...S.choiceCard, ...(form.waste===wt.id ? S.choiceActive : {}) }}
                onClick={() => setForm(f => ({ ...f, waste:wt.id }))}>
                <span style={{ fontSize:26 }}>{wt.icon}</span>
                <span style={{ fontSize:10.5, fontWeight:700 }}>{wt.label}</span>
                <span style={{ fontSize:9, color:"#888" }}>{wt.factor} kgCO₂e/kg</span>
                <span style={{ fontSize:8.5, background:"#e8f5e9", color:"#145a32", padding:"1px 5px", borderRadius:8 }}>{wt.std}</span>
              </button>
            ))}
          </div>
        </div>
      )}

      {/* Step 2: Quantity */}
      {step === 2 && (
        <div style={S.col20}>
          <StepTitle>ปริมาณโดยประมาณ</StepTitle>
          {QUANTITIES.map(qt => (
            <button key={qt.id} style={{ ...S.choiceRow, ...(form.qty===qt.id ? S.choiceActive : {}) }}
