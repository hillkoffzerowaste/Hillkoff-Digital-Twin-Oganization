        <div style={{ fontSize:12, opacity:0.75 }}>GHG Protocol · WEEE · SDG 12</div>
      </div>

      <div style={{ display:"flex", gap:8 }}>
        {[["all","ทั้งหมด"],["monthly","เดือนนี้"],["yearly","ปีนี้"]].map(([p,l]) => (
          <button key={p} style={{ ...S.periodBtn, flex:1, ...(period===p ? S.periodActive : {}) }}
            onClick={() => setPeriod(p)}>{l}</button>
