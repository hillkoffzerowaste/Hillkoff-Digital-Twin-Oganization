<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0" />
    <title>Hillkoff Zero Waste Platform</title>
    <link href="https://fonts.googleapis.com/css2?family=Sarabun:wght@400;600;700;800;900&display=swap" rel="stylesheet" />
    <script src="https://unpkg.com/react@18/umd/react.production.min.js" crossorigin></script>
    <script src="https://unpkg.com/react-dom@18/umd/react-dom.production.min.js" crossorigin></script>
    <script src="https://unpkg.com/@babel/standalone/babel.min.js"></script>
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
        body { font-family: 'Sarabun', sans-serif; background: #f0f7f2; min-height: 100vh; }
        #root { padding-bottom: 80px; }
        /* สไตล์เพิ่มเติมดึงมาจากต้นฉบับเพื่อความสวยงาม */
        .card { background: white; padding: 20px; border-radius: 12px; box-shadow: 0 4px 6px rgba(0,0,0,0.1); margin: 15px; }
        .hero { background: linear-gradient(135deg,#145a32,#1e8449); color: white; padding: 30px; border-radius: 0 0 25px 25px; text-align: center; }
        button { cursor: pointer; border: none; transition: 0.2s; }
        .nav-bar { position: fixed; bottom: 0; width: 100%; background: white; display: flex; border-top: 1px solid #ddd; }
        .nav-item { flex: 1; padding: 15px; text-align: center; background: none; }
    </style>
</head>
<body>
    <div id="root"></div>

    <script type="text/babel">
        const { useState, useEffect, useRef } = React;

        // --- Configuration ---
        const GEMINI_KEY = "AIzaSyC97a8JLeMNFtQc7ikvACU4PJMDfF_o2nQ"; 

        const BRANCHES = [
            { id: "hq", name: "สำนักงานใหญ่", short: "HQ", icon: "🏢", color: "#145a32" },
            { id: "changphueak", name: "ช้างเผือก", short: "CPK", icon: "🐘", color: "#1e8449" }
        ];

        const WASTE_TYPES = [
            { id: "coffee_grounds", label: "กากกาแฟ", icon: "☕", factor: 0.49, unit: "kg" },
            { id: "plastic", label: "พลาสติก", icon: "🧴", factor: 2.53, unit: "kg" }
        ];

        const DISPOSALS = [
            { id: "recycle", label: "รีไซเคิล", icon: "♻️", mult: 0.10 },
            { id: "landfill", label: "ฝังกลบ", icon: "⛏️", mult: 1.00 }
        ];

        // --- Main App Component ---
        function App() {
            const [view, setView] = useState("home");
            const [records, setRecords] = useState([]);

            // โหลดข้อมูลจาก LocalStorage
            useEffect(() => {
                const saved = localStorage.getItem("hk_v2_records");
                if (saved) setRecords(JSON.parse(saved));
            }, []);

            const saveRecord = (data) => {
                const updated = [data, ...records];
                setRecords(updated);
                localStorage.setItem("hk_v2_records", JSON.stringify(updated));
                setView("home");
            };

            const totalCO2 = records.reduce((sum, r) => sum + (r.co2e || 0), 0);

            return (
                <div style={{ position: 'relative' }}>
                    <div className="hero">
                        <div style={{fontSize: '12px', opacity: 0.8}}>Hillkoff Zero Waste</div>
                        <h1 style={{fontSize: '32px'}}>{totalCO2.toFixed(2)} <span style={{fontSize: '16px'}}>kg CO₂e</span></h1>
                    </div>

                    {view === "home" ? (
                        <div className="card">
                            <h3>รายการล่าสุด</h3>
                            {records.length === 0 ? <p style={{color: '#999', marginTop: '10px'}}>ยังไม่มีข้อมูล</p> : 
                                records.map(r => (
                                    <div key={r.id} style={{padding: '10px 0', borderBottom: '1px solid #eee'}}>
                                        <strong>{r.wasteLabel}</strong> - {r.co2e} kg CO₂e
                                        <div style={{fontSize: '10px', color: '#888'}}>{new Date(r.ts).toLocaleString('th-TH')}</div>
                                    </div>
                                ))
                            }
                        </div>
                    ) : (
                        <div className="card">
                            <h3>บันทึกข้อมูลใหม่</h3>
                            <p>เลือกประเภทขยะและปริมาณเพื่อคำนวณ</p>
                            <br />
                            <button 
                                onClick={() => saveRecord({
                                    id: Date.now(),
                                    ts: new Date().toISOString(),
                                    wasteLabel: "กากกาแฟ",
                                    co2e: 0.49
                                })}
                                style={{background: '#27ae60', color: 'white', padding: '15px', borderRadius: '8px', width: '100%'}}
                            >
                                บันทึกตัวอย่าง (กากกาแฟ 1 กก.)
                            </button>
                        </div>
                    )}

                    <nav className="nav-bar">
                        <button className="nav-item" onClick={() => setView("home")}>🏠 หน้าหลัก</button>
                        <button className="nav-item" onClick={() => setView("log")}>📝 บันทึก</button>
                    </nav>
                </div>
            );
        }

        const root = ReactDOM.createRoot(document.getElementById('root'));
        root.render(<App />);
    </script>
</body>
</html>
