                </div>
              </div>
              <span style={{ fontSize:12, color:"#888" }}>×{dp.mult}</span>
            </button>
          ))}
          {co2Preview !== null && (
            <div style={S.co2PreviewBox}>
              <span style={{ fontSize:13, opacity:0.85 }}>CO₂e ที่ปล่อย (GHG Scope 3)</span>
              <span style={{ fontSize:32, fontWeight:900, color: co2Preview < 1 ? "#a8e6cf" : "#ff8a80" }}>{co2Preview} kg</span>
            </div>
          )}
        </div>
      )}

      {/* Step 4: Photo + AI */}
      {step === 4 && (
        <div style={S.col20}>
          <StepTitle>ถ่ายรูป + Gemini Vision AI</StepTitle>
          <div style={S.summaryBox}>
            {[
              ["สาขา",    BRANCHES.find(b=>b.id===form.branch)?.name],
