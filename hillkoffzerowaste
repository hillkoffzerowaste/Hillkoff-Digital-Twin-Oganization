      </div>

      <div style={S.summaryBox}>
        <div style={S.summaryRow}><span>CO₂e รวม</span><span style={{ fontWeight:800, color:"#145a32", fontSize:16 }}>{fTotal} kg</span></div>
        <div style={S.summaryRow}><span>เทียบเป็น tCO₂e</span><span style={{ fontWeight:700 }}>{(fTotal*0.001).toFixed(6)} t</span></div>
        <div style={S.summaryRow}><span>รายการทั้งหมด</span><span style={{ fontWeight:700 }}>{filtered.length} รายการ</span></div>
        <div style={S.summaryRow}><span>AI ยืนยัน</span><span style={{ fontWeight:700 }}>{filtered.filter(r=>r.aiMatch).length} รายการ</span></div>
        <div style={S.summaryRow}><span>Gemini Vision</span><span style={{ fontWeight:700 }}>{filtered.filter(r=>r.geminiUsed).length} รายการ</span></div>
      </div>

      <SectionTitle>ส่งออกรายงาน</SectionTitle>
      <button style={{ ...S.exportBtn, background:"#145a32" }} onClick={() => exportCSV(filtered)}>
        📊 Export CSV (Excel/Sheets)
      </button>
      <button style={{ ...S.exportBtn, background:"#1e6aa8" }} onClick={() => exportPDF(filtered, fStats, fTotal)}>
        📄 Export PDF (ISO 14064 Report)
      </button>

      <SectionTitle>📧 ส่งรายงานทาง Gmail</SectionTitle>
      <div style={S.gmailCard}>
        <div style={{ fontSize:12, color:"#555", marginBottom:8 }}>
          ส่งรายงาน ESG สรุปให้ผู้บริหารโดยตรง<br />
          <span style={{ fontSize:10, color:"#27ae60" }}>⚡ เชื่อม Gmail MCP จากเมนู Settings เพื่อส่งจริง</span>
        </div>
        <input style={S.emailInput} placeholder="อีเมลผู้รับ เช่น ceo@hillkoff.com"
          value={emailTo} onChange={e => setEmailTo(e.target.value)} type="email" />
